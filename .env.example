# Shared app + worker runtime envs

# Supabase (required for app, admin APIs, and worker runtime)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="cms-media"

# Site identity (required for public app output and admin branding)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="Your Site Name"

# App port (used by Docker, deploy scripts, and Next.js standalone server)
PORT=3010

# Local worker runtime (shared with the Docker worker service)
AGENT_WORKER_POLL_INTERVAL_MS=5000
AGENT_WORKER_STALE_AFTER_MS=60000
# AGENT_WORKER_ID="agent-worker-local"

# Blog ingest webhook auth
BLOG_INGEST_API_KEY="change-me"

# Optional generated-image provider for blog placeholders and agent-created media.
# Leave GEMINI_API_KEY empty only if you accept generated images being unavailable.
GEMINI_API_KEY=""
GEMINI_PLANNER_MODEL="gemini-2.5-flash"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image-preview"

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=    # Measurement ID (e.g. G-XXXXXXXXXX)
